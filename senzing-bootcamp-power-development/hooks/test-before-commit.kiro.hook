{
  "name": "Run Tests Before Commit",
  "version": "1.0.0",
  "description": "Run tests when source files are saved to catch issues early",
  "when": {
    "type": "fileEdited",
    "patterns": ["src/**/*.py", "src/**/*.js"]
  },
  "then": {
    "type": "runCommand",
    "command": "python -m pytest tests/ -v",
    "timeout": 60
  }
}
