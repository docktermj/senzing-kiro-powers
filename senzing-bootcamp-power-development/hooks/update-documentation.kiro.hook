{
  "name": "Update Documentation Reminder",
  "version": "1.0.0",
  "description": "Remind to update documentation when programs are modified",
  "when": {
    "type": "fileEdited",
    "patterns": ["src/**/*.py", "src/**/*.js"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A program was modified. Please remind the user to update the corresponding documentation in the docs/ folder and add comments explaining any complex logic."
  }
}
